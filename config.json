{
  "name": "Timeframe",
  "version": "1.0.24",
  "slug": "timeframe",
  "description": "An e-paper calendar, weather, and smart home family dashboard",
  "url": "https://github.com/joelhawksley/timeframe",
  "arch": ["aarch64", "amd64"],
  "homeassistant_api": true,
  "hassio_role": "default",
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:calendar-clock",
  "panel_title": "Timeframe",
  "map": ["data:rw"],
  "ports": {
    "8099/tcp": 8099,
    "11113/tcp": 11113
  },
  "ports_description": {
    "8099/tcp": "Web interface",
    "11113/tcp": "Visionect device protocol"
  },
  "options": {
    "speed_unit": "mph",
    "precipitation_unit": "in",
    "temperature_unit": "F"
  },
  "schema": {
    "speed_unit": "list(mph|kph)",
    "precipitation_unit": "list(in|mm)",
    "temperature_unit": "list(F|C)"
  }
}
