{
  "name": "Timeframe",
  "version": "2.1.0",
  "slug": "timeframe",
  "description": "An e-paper calendar, weather, and smart home family dashboard",
  "url": "https://github.com/timeframe/timeframe",
  "arch": [
    "aarch64",
    "amd64"
  ],
  "homeassistant_api": true,
  "hassio_role": "default",
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:calendar-clock",
  "panel_title": "Timeframe",
  "host_network": true,
  "map": [
    "data:rw"
  ],
  "ports": {
    "8099/tcp": 8099
  },
  "ports_description": {
    "8099/tcp": "Web interface"
  },
  "options": {
    "speed_unit": "mph",
    "precipitation_unit": "in",
    "temperature_unit": "F"
  },
  "schema": {
    "speed_unit": "list(mph|kph)",
    "precipitation_unit": "list(in|mm)",
    "temperature_unit": "list(F|C)"
  }
}
