#!/bin/bash
set -e

PGDATA="/data/pgdata"

# Initialize PostgreSQL if needed
if [ ! -f "$PGDATA/PG_VERSION" ]; then
  mkdir -p "$PGDATA"
  chown postgres:postgres "$PGDATA"
  su postgres -c "initdb -D $PGDATA"
fi

chown -R postgres:postgres "$PGDATA"

# Start PostgreSQL
su postgres -c "pg_ctl start -D $PGDATA -l /data/postgresql.log -w"

# Create database if it doesn't exist
su postgres -c "createdb timeframe_production" 2>/dev/null || true

# Run migrations
export DATABASE_URL="postgres:///timeframe_production"
bundle exec rails db:migrate

# Start Puma
exec bundle exec puma -C config/puma.rb
