<% unless view_object[:private_mode] %>
  <style>
    table.single td {
      padding: 1px 0;
    }
    body {
      padding: 16px 16px 16px 0;
      font-family: 'Lato', sans-serif;
      font-size: 28px;
      -webkit-font-smoothing: antialiased;
    }
  </style>
  <table style="font-size: 28px;" class="single">
    <% view_object[:day_groups].each_with_index do |event_day, index| %>
      <tr>
        <td colspan="1"></td>
        <td colspan="2" style="font-family: 'Lato', sans-serif; font-size: 60px; font-weight: 700; line-height: 1;"><%= event_day[:day_name] %></td>
      </tr>
      <% if event_day[:show_daily] %>
        <% event_day[:daily].each do |event| %>
          <tr>
            <td style="width: 1%;"></td>
            <td style="width: 1%; text-align: center; font-family: 'Lato', sans-serif; font-size: 40px; font-weight: bold;">
              <% if event[:icon_text] %>
                <span><%= event[:icon_text] %></span>
              <% else %>
                <i class="mdi mdi-<%= event[:icon_class] %>" style="font-size: 40px;<%= " #{event[:icon_style]}" if event[:icon_style] %>"></i>
              <% end %>
            </td>
            <td style="padding-left: 8px;">
              <%= event[:summary] %>
              <div style="font-family: 'Lato', sans-serif; font-size: 14px;"><%= event[:location] %></div>
            </td>
          </tr>
        <% end %>
      <% end %>
      <% event_day[:periodic].each do |event| %>
        <tr>
          <td style="white-space: nowrap; font-family: 'Lato', sans-serif; font-size: 16px; padding-right: 16px; text-align: right; width: 1%">
            <%= event[:time_html].html_safe %>
          </td>
          <td style="text-align: center; font-family: 'Lato', sans-serif; font-size: 40px; font-weight: bold; width: 1%;">
            <% if event[:icon_text] %>
              <span><%= event[:icon_text] %></span>
            <% else %>
              <i class="mdi mdi-<%= event[:icon_class] %>" style="font-size: 40px;<%= " #{event[:icon_style]}" if event[:icon_style] %>"></i>
            <% end %>
          </td>

          <td style="text-overflow: ellipsis; white-space: nowrap; overflow: hidden; max-width: 0; padding-left: 8px;">
            <%= event[:summary] %>
          </td>
        </tr>
      <% end %>
      <tr><td colspan="3"><hr style="margin: 8px 32px; border: none; background-color: #000; color: #000; height: 2px;"></td></tr>
    <% end %>
  </table>

<% end %>

<div class="timestamp" style="position: absolute; bottom: 4px; right: 4px; font-family: 'Lato', sans-serif; font-size: 9px; z-index: 10; writing-mode: vertical-rl; text-orientation: mixed;">
  <%= view_object[:attribution] if view_object[:attribution].present? %> <%= view_object[:timestamp] %>
</div>
