#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CORE_DIR="$(dirname "$SCRIPT_DIR")"
HA_ADDON_DIR="$CORE_DIR/../ha-addon"
CLOUD_DIR="$CORE_DIR/../cloud"

run_checks() {
  local dir="$1"
  local name="$2"
  shift 2
  local env_vars=("$@")

  if [ ! -d "$dir" ]; then
    echo "⚠ $name not found at $dir, skipping"
    return 0
  fi

  echo "▶ $name: standardrb"
  if ! (cd "$dir" && bundle exec standardrb); then
    echo "✗ $name: standardrb failed"
    return 1
  fi

  echo "▶ $name: tests"
  if ! (cd "$dir" && env "${env_vars[@]}" bundle exec rake test); then
    echo "✗ $name: tests failed"
    return 1
  fi

  echo "✓ $name passed"
}

echo "Running checks for core consumers..."
echo ""

run_checks "$HA_ADDON_DIR" "ha-addon" TIMEFRAME_HOME_ASSISTANT_TOKEN=test
echo ""
run_checks "$CLOUD_DIR" "cloud" \
  SECRET_KEY_BASE=test \
  ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=test \
  ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=test \
  ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=test \
  || echo "⚠ cloud checks failed (cloud may not be fully set up yet)"

echo ""
echo "✓ All checks passed"
