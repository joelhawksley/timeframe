<div class="fade-bottom"></div>
<div id="flash-overlay" style="display:none; position: absolute; left: 0; right: 0; top: 0; bottom: 0; z-index: 100"></div>
<style>html { font-size: 44px; }</style>
<div class="timestamp" style="position: absolute; bottom: .25rem; right: .25rem; font-size: .4rem; color: #777; z-index: 10; writing-mode: vertical-rl; text-orientation: mixed;">
  <%= view_object[:attribution] if view_object[:attribution].present? %> <%= view_object[:timestamp] %>
</div>
<% if view_object[:top_left].any? || view_object[:top_right].any? || view_object[:weather_status].any? %>
<div style="clear: both; line-height: .7; margin-bottom: 1rem;">
  <div style="float: left;">
<%- (view_object[:top_left] + view_object[:weather_status]).each do |top_left| -%>
<span style="margin-right: .5rem;"><i class="mdi mdi-<%= top_left[:icon] %>" style="margin-right: .1rem;<%= " display: inline-block; transform: rotate(#{top_left[:rotation]}deg);" if top_left[:rotation] %>"></i><%= top_left[:label] %></span>
<%- end -%>
  </div>
  <div style="float: right; text-align: right;">
<%- view_object[:top_right].each do |top_right| -%>
<span><i class="mdi mdi-<%= top_right[:icon] %>" style="margin-right: .1rem;"></i><%= top_right[:label] %></span>
<%- end -%>
  </div>
  <div>&nbsp;</div>
</div>
<hr style="margin: 1rem 0 1rem; border: none; background-color: #ccc; color: #ccc; height: 2px;">
<% end %>
<div style="clear: both; line-height: .7; margin-bottom: 1rem; padding-bottom: .5rem; font-size: 3rem;">
  <div style="float: left;">
    <%= DateTime.now.strftime("%A, %b. %-d") %>
  </div>
  <div style="float: right; text-align: right;">
    <%= view_object[:current_temperature] %>
  </div>
  <div>&nbsp;</div>
</div>
<% unless view_object[:private_mode] %>
  <hr style="margin: 1rem 0 1rem; border: none; background-color: #ccc; color: #ccc; height: 2px;">
  <%= render "devices/timeline", view_object: view_object %>
<% end %>

<script>
(function() {
  function checkFlash() {
    var now = new Date();
    var overlay = document.getElementById('flash-overlay');
    if (!overlay) return;
    if (now.getMinutes() === 0 && now.getSeconds() < 8) {
      var s = now.getSeconds();
      overlay.style.display = 'block';
      overlay.style.backgroundColor = (s % 4 < 2) ? 'black' : 'white';
    } else {
      overlay.style.display = 'none';
    }
  }

  checkFlash();
  setInterval(checkFlash, 1000);

  <% if @refresh %>
    var knownDeployTime = '<%= DEPLOY_TIME %>';
    var deviceUrl = '<%= account_location_device_path(account_id: params[:account_id], location_id: params[:location_id], id: @device.id) %>';
    var cable = ActionCable.createConsumer();
    cable.subscriptions.create(
      { channel: 'DeviceChannel', device_id: '<%= @device.id %>' },
      {
        received: function(data) {
          if (data.deploy_time && data.deploy_time.toString() !== knownDeployTime) {
            window.location.reload();
            return;
          }
          if (data.action === 'refresh') {
            fetch(deviceUrl + '?layout=false')
              .then(function(r) { return r.text(); })
              .then(function(html) {
                document.body.innerHTML = html;
              })
              .catch(function(e) { console.error('[Timeframe] Refresh failed:', e); });
          }
        }
      }
    );
  <% end %>
})();
</script>
