<style>
  html, body { margin: 0; padding: 0; font-size: 16px; }
  .three-day-columns { display: flex; height: 100vh; gap: .35rem; padding: 1.5rem; box-sizing: border-box; }
  .three-day-col { flex: 1; padding: .35rem .5rem; overflow: hidden; border: 2px solid #000; border-radius: .35rem; align-self: stretch; }
  .three-day-col-other { border-color: rgba(204, 204, 204, .5); }
  .three-day-header { text-align: center; font-weight: 700; font-size: 1.875rem; line-height: 1.2; margin-bottom: .25rem; }
  .three-day-date { font-size: 1.5rem; font-weight: 400; line-height: 1.2; }
  .three-day-weather-row { display: flex; justify-content: space-between; margin-bottom: .25rem; }
  .three-day-weather-item { display: flex; flex-direction: column; align-items: center; flex: 1 1 0; border: 1px solid #ccc; border-radius: .25rem; padding: .2rem .1rem; margin: 0 .1rem; min-width: 0; }
  .three-day-weather-item i { font-size: 1.5rem; }
  .three-day-weather-time { font-size: .75rem; }
  .three-day-weather-temp { font-size: 1rem; }
  .three-day-events { font-size: 1.25rem; }
  .three-day-events table { width: 100%; border-collapse: collapse; }
  .three-day-events td { padding: .05rem 0; }
  .three-day-event-icon { width: 1rem; text-align: center; font-size: .85rem; font-weight: bold; }
  .three-day-event-summary { text-overflow: ellipsis; white-space: nowrap; overflow: hidden; max-width: 0; }
</style>

<% unless view_object[:private_mode] %>
  <div class="three-day-columns">
    <% view_object[:day_groups].each do |day| %>
      <div class="three-day-col<%= ' three-day-col-other' unless day[:date].to_date == Date.current %>">
        <div class="three-day-header">
          <div><%= day[:day_name] %></div>
          <div class="three-day-date"><%= day[:date].strftime("%B %-d") %></div>
        </div>

        <% if day[:weather_row]&.any? %>
          <div class="three-day-weather-row">
            <% day[:weather_row].each do |w| %>
              <span class="three-day-weather-item">
                <span class="three-day-weather-time"><%= w[:start_time] %></span>
                <i class="mdi mdi-<%= w[:icon_class] %>"></i>
                <span class="three-day-weather-temp"><%= w[:summary] %></span>
              </span>
            <% end %>
          </div>
        <% end %>

        <% if day[:show_daily] && day[:daily].any? %>
          <div class="three-day-events">
            <table>
              <% day[:daily].each do |event| %>
                <tr>
                  <td class="three-day-event-icon">
                    <% if event[:icon_text] %>
                      <span><%= event[:icon_text] %></span>
                    <% else %>
                      <i class="mdi mdi-<%= event[:icon_class] %>"<%= " style=\"#{event[:icon_style]}\"".html_safe if event[:icon_style] %>></i>
                    <% end %>
                  </td>
                  <td class="three-day-event-summary"><%= event[:summary] %></td>
                </tr>
              <% end %>
            </table>
          </div>
        <% end %>

        <% if day[:periodic].any? %>
          <div class="three-day-events">
            <table>
              <% day[:periodic].each do |event| %>
                <tr>
                  <td style="white-space: nowrap; font-size: .9375rem; padding: 0 .15rem 0 0; width: 2.5rem;">
                    <%= view_object[:start_time_only] ? event[:start_time] : event[:time_html].html_safe %>
                  </td>
                  <td class="three-day-event-summary"><%= event[:summary] %></td>
                </tr>
              <% end %>
            </table>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<div class="timestamp" style="position: absolute; bottom: 4px; right: 4px; font-family: 'Lato', sans-serif; font-size: 9px; z-index: 10; writing-mode: vertical-rl; text-orientation: mixed;">
  <%= view_object[:attribution] if view_object[:attribution].present? %> <%= view_object[:timestamp] %>
</div>
