<!DOCTYPE html>
<html>
  <head>
    <title>Preview – <%= @device.name %></title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { background: #333; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
      .frame {
        background: #fff;
        border-radius: 8px;
        padding: 8px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3);
      }
      iframe { border: none; display: block; }
    </style>
  </head>
  <body>
    <div class="frame">
      <iframe
        src="<%= @display_url %>"
        width="<%= @width %>"
        height="<%= @height %>"
        scrolling="no"
        style="transform: scale(var(--scale)); transform-origin: top left;">
      </iframe>
    </div>
    <script>
      (function() {
        var nativeW = <%= @width %>;
        var nativeH = <%= @height %>;
        function fit() {
          var scale = Math.min((window.innerWidth * 0.9) / nativeW, (window.innerHeight * 0.9) / nativeH, 1);
          document.documentElement.style.setProperty('--scale', scale);
          var frame = document.querySelector('.frame');
          frame.style.width = Math.round(nativeW * scale) + 16 + 'px';
          frame.style.height = Math.round(nativeH * scale) + 16 + 'px';
        }
        fit();
        window.addEventListener('resize', fit);
      })();
    </script>
  </body>
</html>
