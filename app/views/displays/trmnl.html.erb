<div class="fade-bottom"></div>

<% unless HomeAssistantApi.new.private_mode? %>
  <%= render "timeline_single", view_object: view_object %>
<% end %>

<div class="timestamp" style="position: absolute; bottom: 0.25rem; right: 0.25rem; font-size: 0.35rem; color: #999; z-index: 10; writing-mode: vertical-rl; text-orientation: mixed;">
  <%= view_object[:attribution] if view_object[:attribution].present? %> <%= view_object[:timestamp] %>
</div>
