<h2 class="h5 mb-3">Home Assistant Status</h2>

<div class="card mb-4">
  <div class="card-header">
    <h3 class="h6 mb-0">API Status</h3>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-bordered table-sm">
        <thead class="table-light">
          <tr>
            <th>API</th>
            <th>Status</th>
            <th>Last Fetched</th>
          </tr>
        </thead>
        <tbody>
          <% @statuses.each do |status| %>
            <tr>
              <td><i class="mdi <%= status[:icon] %>"></i> <%= status[:name] %></td>
              <td><%= status[:healthy] ? "✓ Healthy" : "✗ Unhealthy" %></td>
              <td><%= status[:last_fetched_at] ? DateTime.parse(status[:last_fetched_at]).strftime("%b %-d @ %-l:%M:%S %p") : "Never" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h3 class="h6 mb-0">Config</h3>
  </div>
  <div class="card-body">
    <% config_data = @api.config_data %>
    <% if config_data.present? %>
      <div class="table-responsive">
        <table class="table table-bordered table-sm">
          <thead class="table-light">
            <tr>
              <th>Key</th>
              <th>Value</th>
            </tr>
          </thead>
          <tbody>
            <% config_data.each do |key, value| %>
              <tr>
                <td><%= key %></td>
                <td class="text-truncate"><%= value.is_a?(Hash) ? value.to_json : value %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted">No config data available.</p>
    <% end %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h3 class="h6 mb-0">Now Playing</h3>
  </div>
  <div class="card-body">
    <% now_playing = @api.now_playing %>
    <% if now_playing.present? %>
      <div class="table-responsive">
        <table class="table table-bordered table-sm">
          <thead class="table-light">
            <tr>
              <th>Artist</th>
              <th>Track</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><%= now_playing[:artist] %></td>
              <td><%= now_playing[:track] %></td>
            </tr>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted">Nothing playing.</p>
    <% end %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h3 class="h6 mb-0">Calendar Events (<%= @api.calendar_events.length %>)</h3>
  </div>
  <div class="card-body">
    <% if @api.calendar_events.present? %>
      <div class="table-responsive">
        <table class="table table-bordered table-sm">
          <thead class="table-light">
            <tr>
              <th>Icon</th>
              <th>Daily?</th>
              <th>Summary</th>
              <th>Starts At</th>
              <th>Ends At</th>
              <th>ID</th>
              <th>Location</th>
            </tr>
          </thead>
          <tbody>
            <% @api.calendar_events.sort_by(&:start_i).each do |event| %>
              <tr>
                <td><%= event.icon %></td>
                <td><%= event.daily? %></td>
                <td><%= event.summary %></td>
                <td><%= event.starts_at.strftime("%b %-d @ %-l:%M %p") %></td>
                <td><%= event.ends_at.strftime("%b %-d @ %-l:%M %p") %></td>
                <td><%= event.id %></td>
                <td><%= event.location %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted">No calendar events.</p>
    <% end %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h3 class="h6 mb-0">Hourly Forecast (<%= @api.hourly_forecast.length %>)</h3>
  </div>
  <div class="card-body">
    <% if @api.hourly_forecast.present? %>
      <div class="table-responsive">
        <table class="table table-bordered table-sm">
          <thead class="table-light">
            <tr>
              <% @api.hourly_forecast.first.keys.each do |key| %>
                <th><%= key %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @api.hourly_forecast.each do |hour| %>
              <tr>
                <% hour.values.each do |value| %>
                  <td><%= value %></td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted">No hourly forecast data.</p>
    <% end %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h3 class="h6 mb-0">Daily Forecast (<%= @api.daily_forecast.length %>)</h3>
  </div>
  <div class="card-body">
    <% if @api.daily_forecast.present? %>
      <div class="table-responsive">
        <table class="table table-bordered table-sm">
          <thead class="table-light">
            <tr>
              <% @api.daily_forecast.first.keys.each do |key| %>
                <th><%= key %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @api.daily_forecast.each do |day| %>
              <tr>
                <% day.values.each do |value| %>
                  <td><%= value %></td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted">No daily forecast data.</p>
    <% end %>
  </div>
</div>
